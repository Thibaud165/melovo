# Copier ce fichier en .env puis remplir les valeurs.

# Port d'écoute de l'application
PORT=8080

# Secret des sessions (longue chaîne aléatoire, ex. `openssl rand -hex 32`)
SESSION_SECRET=change-me-please

# Compte administrateur seedé au premier démarrage
ADMIN_USERNAME=thibaud.jourdan
ADMIN_PASSWORD=motdepasse-provisoire
